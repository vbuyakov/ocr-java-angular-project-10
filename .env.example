# Database (container init)
POSTGRES_DB=ycyw
POSTGRES_USER=ycyw_user
POSTGRES_PASSWORD=changeme

# JDBC URL for Spring Boot — must use database name POSTGRES_DB above.
# With Docker Compose, host is the service name "postgres".
# When running the API on the host (./gradlew bootRun), use localhost instead.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ycyw

# JWT
JWT_SECRET=changeme_use_a_long_random_string_in_production
JWT_EXPIRATION_MS=86400000

# Ports (published on the host)
POSTGRES_PORT=5432
API_PORT=8080
WEB_PORT=4200

# Angular (browser): REST + WebSocket SockJS use this as origin — compiled into
# web/src/environments/environment.prod.ts at docker build (see web/Dockerfile).
# Default when unset: http://localhost:${API_PORT}
API_BASE_URL=http://localhost:8080

# Optional override — Docker Compose sets FRONTEND_ORIGIN=http://localhost:${WEB_PORT} for the API
# FRONTEND_ORIGIN=http://localhost:4200

# Database (container init)
POSTGRES_DB=ycyw
POSTGRES_USER=ycyw_user
POSTGRES_PASSWORD=changeme

# JDBC URL for Spring Boot — must use database name POSTGRES_DB above.
# With Docker Compose, host is the service name "postgres".
# When running the API on the host (./gradlew bootRun), use localhost instead.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ycyw

# JWT
JWT_SECRET=changeme_use_a_long_random_string_in_production
JWT_EXPIRATION_MS=86400000

# Ports (published on the host)
POSTGRES_PORT=5432
# Single public port for the app (edge nginx → container :80), same idea as conf-samples.
# Use 4200 if port 80 is already taken on your machine.
APP_PORT=80

# Optional override — Docker Compose sets FRONTEND_ORIGIN=http://localhost:${APP_PORT}
# FRONTEND_ORIGIN=http://localhost:80

# devops/seed_users.py: uses APP_PORT for POST /auth/register (same URL as the browser).
# Override with SEED_API_BASE_URL if needed. Agent promotion needs Postgres on the host
# (use docker-compose.dev.yml to publish :5432) or set POSTGRES_HOST.
